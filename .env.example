# App
APP_URL=https://artist.example.com
APP_NAME=Artist Member Site
NODE_ENV=production
# Informational startup log and readiness warning only. v1.0 auth/file rate limits are
# process-local; values above 1 require an external shared limiter in a later phase.
APP_INSTANCE_COUNT=1

# Security
# Document CSP rollout. "auto" enforces unless an executable legacy footer still
# needs migration; in that case the browser receives Report-Only until migration.
# "report-only" is for explicit observation; "enforce" never executes legacy code.
SECURITY_CSP_MODE=auto
# Enable only after confirming this deployment is served exclusively through HTTPS.
# HSTS is disabled by default and does not include preload.
SECURITY_HSTS_ENABLED=false
# Session secret for cookies and in-flight encrypted login-code tasks.
# Docker Compose automatically creates a persistent file-backed secret on first start
# (mode 0600 on the `secrets` volume at SESSION_SECRET_FILE, default
# /app/secrets/session-secret) and reuses it across restarts and recreation.
# Non-Compose deployments must provide SESSION_SECRET or SESSION_SECRET_FILE themselves;
# in production the app refuses to start with an empty/short/`change-me` value.
# Generate an external value with: openssl rand -base64 32
# SESSION_SECRET=
# Advanced: set SESSION_SECRET to an externally managed value (never written to disk), or
# point SESSION_SECRET_FILE at a custom path. A custom path must be *inside the container*
# and its directory must be mounted (e.g. a Compose volume); all app/dispatcher replicas
# must read the same value.
# SESSION_SECRET_FILE=/app/secrets/session-secret

# Cloudflare Turnstile (bot protection for email login-code requests)
# Set TURNSTILE_ENABLED=true and fill both keys to enable.
# TURNSTILE_SECRET_KEY is server-side only and never sent to the browser.
TURNSTILE_ENABLED=false
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Config Encryption (root key for encrypted settings / config center)
# Docker users can leave both empty: a random key is generated on first start
# and persisted to the `secrets` volume at CONFIG_ENCRYPTION_KEY_FILE.
# IMPORTANT: back up /app/secrets/config-encryption-key (or the volume) when
# migrating servers. If the key is lost, encrypted settings cannot be decrypted.
CONFIG_ENCRYPTION_KEY=
CONFIG_ENCRYPTION_KEY_FILE=/app/secrets/config-encryption-key

# Database
DATABASE_URL=postgresql://artist:artist_password@postgres:5432/artist_member

# Migration runtime
# Optional. Docker entrypoint uses these when applying migrations before app start.
MIGRATE_MAX_ATTEMPTS=30
# MIGRATIONS_FOLDER=/app/src/db/migrations

# Mail
# These act as the fallback source. Once configured in the admin config center,
# the database values take precedence (priority: DB > env > default).
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_smtp_user
SMTP_PASSWORD=your_smtp_password
SMTP_FROM="Artist Site <no-reply@example.com>"
# Business email needs-operator retry: 1–1440 minutes; maximum age: 1–168 hours.
EMAIL_RETRY_RECHECK_MINUTES=15
EMAIL_DELIVERY_MAX_AGE_HOURS=24

# Durable task queue pacing. Each value is an integer 0-20 because TASK_BATCH_SIZE
# is 20. Transactional reserve protects login/payment/membership mail when bulk
# notification work is backlogged; notification minimum prevents starvation.
TASK_TRANSACTIONAL_RESERVED_PER_BATCH=8
TASK_NOTIFICATION_MIN_PER_BATCH=2
TASK_NOTIFICATION_STALE_RECLAIM_MAX_PER_BATCH=2
TASK_MAINTENANCE_MAX_PER_BATCH=2

# New-post email notifications. User opt-in defaults off. These limits apply only
# to notification queue send attempts, never to login codes, payment emails,
# membership emails, or renewal reminders.
# Daily budget: 1-100000. Per-minute pacing: 1-10000.
# Expansion batch: 1-5000 users. Delivery max age: 1-720 hours.
# Unsubscribe token max age: 1-3650 days.
NOTIFICATION_EMAIL_DAILY_BUDGET=500
NOTIFICATION_EMAIL_PACING_PER_MINUTE=30
NOTIFICATION_CAMPAIGN_EXPANSION_BATCH_SIZE=500
NOTIFICATION_DELIVERY_MAX_AGE_HOURS=168
NOTIFICATION_UNSUBSCRIBE_TOKEN_MAX_AGE_DAYS=180

# Notification unsubscribe and suppression keys are separate from SESSION_SECRET.
# Docker Compose production starts can leave the current secret values unset: the
# entrypoint creates persistent 0600 files at the *_FILE paths below. Non-Compose
# deployments must provide either a direct secret or a readable regular file.
# Direct non-empty *_SECRET env values take precedence over *_SECRET_FILE.
# Generate external direct values with: openssl rand -base64 32
NOTIFICATION_UNSUBSCRIBE_KEY_ID=current
# NOTIFICATION_UNSUBSCRIBE_SECRET=
NOTIFICATION_UNSUBSCRIBE_SECRET_FILE=/app/secrets/notification-unsubscribe-secret
# NOTIFICATION_UNSUBSCRIBE_PREVIOUS_KEY_ID=previous
# NOTIFICATION_UNSUBSCRIBE_PREVIOUS_SECRET=
# NOTIFICATION_UNSUBSCRIBE_PREVIOUS_SECRET_FILE=/app/secrets/notification-unsubscribe-previous-secret

NOTIFICATION_SUPPRESSION_DIGEST_KEY_ID=current
# NOTIFICATION_SUPPRESSION_DIGEST_SECRET=
NOTIFICATION_SUPPRESSION_DIGEST_SECRET_FILE=/app/secrets/notification-suppression-digest-secret
# NOTIFICATION_SUPPRESSION_DIGEST_PREVIOUS_KEY_ID=previous
# NOTIFICATION_SUPPRESSION_DIGEST_PREVIOUS_SECRET=
# NOTIFICATION_SUPPRESSION_DIGEST_PREVIOUS_SECRET_FILE=/app/secrets/notification-suppression-digest-previous-secret

# Storage
# These values are the fallback source for the admin config center.
# UPLOAD_DIR remains deployment-only and is not editable in the admin UI.
STORAGE_DRIVER=local
UPLOAD_DIR=/app/uploads

# S3-compatible Storage
# Region left blank in the admin UI falls back to S3_REGION. Use "auto"
# explicitly for Cloudflare R2.
S3_ENDPOINT=
S3_REGION=auto
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_FORCE_PATH_STYLE=true

# Request body and upload limits
# JSON: 1 KiB–1 MiB. Stripe webhook: 1 KiB–1 MiB.
# These application limits are authoritative; reverse-proxy limits are only a second layer.
REQUEST_JSON_MAX_BYTES=65536
STRIPE_WEBHOOK_MAX_BYTES=262144
SUBSCRIPTION_RECONCILE_INTERVAL_MINUTES=60
# Manual renewal reminder lead time, 1-90 days.
SUBSCRIPTION_REMINDER_LEAD_DAYS=7
IMAGE_MAX_FRAMES=300
IMAGE_MAX_TOTAL_PIXELS=300000000
MAX_UPLOAD_SIZE_MB=500
# Payment proof/QR file limit: integer 1–100 MiB. Multipart transfer buffering adds
# 256 KiB for boundaries, headers, and text fields before form parsing.
PAYMENT_PROOF_MAX_SIZE_MB=10
PAYMENT_PROOF_RETENTION_DAYS=30
PAYMENT_PROOF_MAX_PER_DAY=20
PROOF_UPLOAD_RESERVATION_TTL_MINUTES=5
# 未保存的正文内联图片在此宽限期后由 durable task 回收（小时）
INLINE_UPLOAD_GRACE_PERIOD_HOURS=24

# Inline video playback / file request limits
# Public S3 videos may use a longer inline signed URL. Login/member videos are
# always proxied through the app and re-authorized for every request.
PUBLIC_VIDEO_SIGNED_URL_TTL_SECONDS=21600
FILE_PREAUTH_RATE_LIMIT_MAX=1200
# Used only when no trusted client IP can be resolved. This is a shared global
# emergency bucket, not per-IP isolation, so keep it substantially higher.
FILE_PREAUTH_UNRESOLVED_RATE_LIMIT_MAX=20000
FILE_PREAUTH_RATE_LIMIT_WINDOW_MS=600000
VIDEO_RANGE_RATE_LIMIT_MAX=600
# Anonymous video requests without a trusted IP share this per-file emergency bucket.
VIDEO_UNRESOLVED_RATE_LIMIT_MAX=10000
VIDEO_RANGE_RATE_LIMIT_WINDOW_MS=600000
# Anonymous non-video downloads without a trusted IP share this emergency bucket.
DOWNLOAD_UNRESOLVED_RATE_LIMIT_MAX=2000

# Authentication rate limits and login-code policy (S4)
# Login codes default to 16-char uppercase Crockford base32 (80-bit). Keep this
# entropy floor even though verify-code now has a target-independent source hard
# budget before comparison: v1.0 rate limits remain process-local and IPs can vary.
LOGIN_CODE_LENGTH=16
LOGIN_CODE_ALPHABET=crockford-base32
ADMIN_LOGIN_RATE_MAX=10
ADMIN_LOGIN_UNRESOLVED_RATE_MAX=100
ADMIN_LOGIN_RATE_WINDOW_MS=600000
# Hard comparison budgets, checked before verifyLoginCode(). Keys contain no email.
VERIFY_CODE_IP_RATE_MAX=30
VERIFY_CODE_UNRESOLVED_RATE_MAX=300
# Resolved email+IP failure accounting, consumed only after incorrect/expired results.
VERIFY_CODE_EMAIL_IP_RATE_MAX=10
VERIFY_CODE_RATE_WINDOW_MS=600000
REQUEST_CODE_IP_RATE_MAX=20
REQUEST_CODE_EMAIL_IP_RATE_MAX=5
REQUEST_CODE_UNRESOLVED_RATE_MAX=100
REQUEST_CODE_RATE_WINDOW_MS=3600000
REQUEST_CODE_SEND_DEDUPE_SECONDS=60

# Reverse Proxy / Client IP
# The app only trusts the proxy layer you configure here. Default 0 means no
# forwarding header is trusted. File requests then use the dedicated high-threshold
# unresolved-client emergency buckets above; they do not skip limiting and do not
# merge into the normal low per-IP buckets. Production logs a rate-limited warning.
#   - Single reverse proxy (Caddy/Nginx/Traefik): TRUSTED_PROXY_HOPS=1
#   - CDN + reverse proxy (two hops): TRUSTED_PROXY_HOPS=2
#   - Cloudflare Tunnel: set TRUSTED_PROXY_HEADER=cf-connecting-ip
# For x-forwarded-for: the client IP is the (HOPS)-th entry from the right.
# Single-value headers (x-real-ip/cf-connecting-ip/true-client-ip) are only safe
# when the origin is not directly exposed (lock down port 3000 / firewall edge IPs).
TRUSTED_PROXY_HOPS=0
TRUSTED_PROXY_HEADER=x-forwarded-for

# Reverse Proxy (Caddy overlay: docker-compose.caddy.yml)
APP_DOMAIN=artist.example.com

# Cloudflare Tunnel
CLOUDFLARE_TUNNEL_TOKEN=

# AI Translation
# AI translation provider settings are configured in Admin -> Settings and stored
# encrypted in app_settings. There is intentionally no public/client env for the
# provider API key. Keep provider keys out of NEXT_PUBLIC_* variables.
